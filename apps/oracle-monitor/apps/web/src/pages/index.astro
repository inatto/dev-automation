---
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://127.0.0.1:8010';
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Oracle Local Monitor</title>
  <style>
    :root { color-scheme: dark; font-family: Inter, ui-sans-serif, system-ui, sans-serif; background:#07111f; color:#e5edf7; }
    * { box-sizing:border-box; }
    body { margin:0; min-height:100vh; background:radial-gradient(circle at top left,#102541 0,#07111f 42%,#040a12 100%); }
    main { width:min(1600px,96vw); margin:0 auto; padding:24px 0 40px; }
    header { display:flex; align-items:flex-start; justify-content:space-between; gap:20px; margin-bottom:16px; }
    h1 { margin:0 0 6px; font-size:clamp(1.5rem,3vw,2.25rem); }
    .muted { color:#91a4bb; }
    .status { display:flex; align-items:center; gap:10px; padding:10px 14px; border:1px solid #24364d; border-radius:999px; background:#0b1727; }
    .dot { width:10px; height:10px; border-radius:50%; background:#f6c453; box-shadow:0 0 16px currentColor; }
    .dot.ok { background:#38d996; } .dot.error { background:#ff6b76; }
    .cards { display:grid; grid-template-columns:repeat(5,minmax(120px,1fr)); gap:12px; margin-bottom:18px; }
    .card,.panel { border:1px solid #203249; background:rgba(9,20,35,.88); border-radius:14px; box-shadow:0 18px 60px rgba(0,0,0,.18); }
    .card { padding:16px; } .card span { color:#91a4bb; font-size:.82rem; } .card strong { display:block; margin-top:7px; font-size:1.8rem; }
    .danger strong { color:#ff7f89; }
    .panel { overflow:hidden; margin-top:16px; }
    .panel-head { display:flex; justify-content:space-between; gap:12px; align-items:center; padding:14px 18px; border-bottom:1px solid #203249; }
    .panel-head h2 { margin:0; font-size:1rem; }
    .table-wrap { overflow:auto; max-height:440px; padding:8px 12px 12px; }
    table { width:100%; border-collapse:separate; border-spacing:0; font-size:.82rem; }
    th,td { padding:12px 14px; border-bottom:1px solid #17283c; text-align:left; vertical-align:top; line-height:1.4; }
    th { position:sticky; top:0; background:#0d1b2d; color:#aab9cb; z-index:1; white-space:nowrap; }
    td { white-space:normal; overflow-wrap:anywhere; word-break:break-word; }
    th:first-child, td:first-child { padding-left:18px; }
    th:last-child, td:last-child { padding-right:18px; }
    tr:hover td { background:#0d1a2a; }
    .table-apps th:first-child, .table-apps td:first-child { min-width:300px; }
    .table-sessions { min-width:1320px; }
    .table-sessions th:nth-child(1), .table-sessions td:nth-child(1) { min-width:86px; }
    .table-sessions th:nth-child(2), .table-sessions td:nth-child(2) { min-width:70px; }
    .table-sessions th:nth-child(3), .table-sessions td:nth-child(3) { min-width:220px; }
    .table-sessions th:nth-child(4), .table-sessions td:nth-child(4) { min-width:140px; }
    .table-sessions th:nth-child(5), .table-sessions td:nth-child(5) { min-width:150px; }
    .table-sessions th:nth-child(6), .table-sessions td:nth-child(6) { min-width:330px; }
    .table-sessions th:nth-child(7), .table-sessions td:nth-child(7) { min-width:180px; }
    .table-sessions th:nth-child(8), .table-sessions td:nth-child(8), .table-sessions th:nth-child(9), .table-sessions td:nth-child(9), .table-sessions th:nth-child(10), .table-sessions td:nth-child(10) { white-space:nowrap; min-width:72px; }
    .table-txs { min-width:960px; }
    .table-empty { color:#aab9cb; }
    .active { color:#58e0a8; } .blocked { color:#ff7f89; font-weight:700; }
    .error-box { display:none; margin:16px 0; padding:14px; border:1px solid #7d2d37; background:#2d1118; color:#ffb8be; border-radius:12px; white-space:pre-wrap; }
    @media(max-width:900px){ .cards{grid-template-columns:repeat(2,1fr)} header{flex-direction:column} }
  </style>
</head>
<body>
<main data-api={apiUrl}>
  <header>
    <div><h1>Oracle Local Monitor</h1></div>
    <div class="status"><span id="dot" class="dot"></span><span id="state">Conectando…</span></div>
  </header>
  <div id="error" class="error-box"></div>
  <section class="cards">
    <div class="card"><span>Conexões</span><strong id="total">–</strong></div>
    <div class="card"><span>Ativas</span><strong id="active">–</strong></div>
    <div class="card"><span>Inativas</span><strong id="inactive">–</strong></div>
    <div class="card danger"><span>Bloqueadas</span><strong id="blocked">–</strong></div>
    <div class="card"><span>Transações</span><strong id="transactions">–</strong></div>
  </section>
  <section class="panel"><div class="panel-head"><h2>Resumo por aplicação</h2><span id="meta" class="muted"></span></div><div class="table-wrap"><table class="table-apps"><thead><tr><th>Aplicação</th><th>Total</th><th>Ativas</th><th>Inativas</th><th>Bloqueadas</th><th>Transações</th></tr></thead><tbody id="apps"></tbody></table></div></section>
  <section class="panel"><div class="panel-head"><h2>Sessões Oracle</h2></div><div class="table-wrap"><table class="table-sessions"><thead><tr><th>SID</th><th>Status</th><th>Aplicação</th><th>Ação</th><th>Máquina</th><th>Programa</th><th>Evento</th><th>Espera</th><th>Bloqueador</th><th>SQL ID</th></tr></thead><tbody id="sessions"></tbody></table></div></section>
  <section class="panel"><div class="panel-head"><h2>Transações abertas</h2></div><div class="table-wrap"><table class="table-txs"><thead><tr><th>SID</th><th>Aplicação</th><th>Início</th><th>Undo blocos</th><th>Undo registros</th><th>SQL ID</th><th>Última atividade</th></tr></thead><tbody id="txs"></tbody></table></div></section>
</main>
<script is:inline>
const main=document.querySelector('main'); const api=main.dataset.api;
const text=(id,v)=>document.getElementById(id).textContent=v ?? '–';
const esc=v=>String(v??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));
const row=cells=>`<tr>${cells.map(v=>`<td>${v}</td>`).join('')}</tr>`;
async function load(){
 const dot=document.getElementById('dot'), state=document.getElementById('state'), error=document.getElementById('error');
 try{
  const response=await fetch(`${api}/api/monitor`,{cache:'no-store'}); const data=await response.json();
  if(!response.ok) throw new Error(data.detail||`HTTP ${response.status}`);
  error.style.display='none'; dot.className='dot ok'; state.textContent=`Online · ${data.latency_ms} ms`;
  ['total','active','inactive','blocked','transactions'].forEach(k=>text(k,data.summary[k]));
  text('meta',`Filtro: ${data.machine_filter||'todas'} · ${new Date(data.generated_at).toLocaleTimeString('pt-BR')}`);
  document.getElementById('apps').innerHTML=data.summary.applications.map(a=>row([esc(a.module),a.total,a.active,a.inactive,`<span class="${a.blocked?'blocked':''}">${a.blocked}</span>`,a.transactions])).join('')||'<tr><td class="table-empty" colspan="6">Nenhuma sessão</td></tr>';
  document.getElementById('sessions').innerHTML=data.sessions.map(s=>row([`${s.sid},${s.serial_number}`,`<span class="${s.status==='ACTIVE'?'active':''}">${esc(s.status)}</span>`,esc(s.module),esc(s.action),esc(s.machine),esc(s.program),esc(s.event),`${esc(s.seconds_in_wait)}s`,s.blocking_session?`<span class="blocked">${esc(s.blocking_session)}</span>`:'',esc(s.sql_id)])).join('')||'<tr><td class="table-empty" colspan="10">Nenhuma sessão</td></tr>';
  document.getElementById('txs').innerHTML=data.transactions.map(t=>row([`${t.sid},${t.serial_number}`,esc(t.module),esc(t.start_time),esc(t.used_ublk),esc(t.used_urec),esc(t.sql_id),`${esc(t.last_call_et)}s`])).join('')||'<tr><td class="table-empty" colspan="7">Nenhuma transação aberta</td></tr>';
  clearTimeout(window.__timer); window.__timer=setTimeout(load,Math.max(1,data.refresh_seconds)*1000);
 }catch(err){ dot.className='dot error'; state.textContent='Falha'; error.style.display='block'; error.textContent=err.message; clearTimeout(window.__timer); window.__timer=setTimeout(load,3000); }
}
load();
</script>
</body></html>
