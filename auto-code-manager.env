# Intervalo entre os ciclos principais, em segundos.
INTERVAL=2

# Intervalo entre limpezas de arquivos Zone.Identifier, em segundos.
ZONE_EVERY=4

# Intervalo entre backups dos projetos, em segundos.
BACKUP_EVERY=15

# Tempo para confirmar que um ZIP terminou de ser gravado, em segundos.
STABLE_WAIT=5

# Quantidade de avisos sonoros após uma importação concluída.
BEEP_REPEATS=1

# Pausa entre os avisos sonoros, em milissegundos.
BEEP_GAP_MS=180

# Tipo de aviso: wave usa o som suave; beep força o beep eletrônico.
BEEP_MODE="wave"

# Volume do WAV no Windows, de 0 a 100. Valor baixo recomendado: 15 a 30.
BEEP_VOLUME=22

# Arquivo WAV usado no aviso. Caminho absoluto calculado a partir da pasta do próprio script.
BEEP_WAVE_FILE="$SCRIPT_DIR/sounds/soft-notification.wav"

# WAV nativo do Windows tentado primeiro. Este arquivo existe em instalações padrão.
BEEP_WINDOWS_WAVE_FILE="C:\\Windows\\Media\\notify.wav"
