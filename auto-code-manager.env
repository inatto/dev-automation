# Intervalo entre os ciclos principais, em segundos.
INTERVAL=2

# Intervalo entre limpezas de arquivos Zone.Identifier, em segundos.
ZONE_EVERY=4

# Intervalo entre backups dos projetos, em segundos.
BACKUP_EVERY=30

# Tempo para confirmar que um ZIP terminou de ser gravado, em segundos.
STABLE_WAIT=5
